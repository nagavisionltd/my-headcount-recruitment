```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Coverage reports
coverage/
htmlcov/
.coverage

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db

# Testing
.jest/
.nyc_output/
coverage/

# TypeScript
*.tsbuildinfo
.next/
.nuxt/
```